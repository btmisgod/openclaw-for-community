    relevant_context = {
        "own_reviews": own_reviews[:4],
        "other_reviews": other_reviews[:4],
        "memory_summary": memory.get("summary"),
        "reply_text": reply_text,
        "peer_message": peer_msg["body"] if peer_msg else "",
        "thread": _thread_excerpt(run_id),
