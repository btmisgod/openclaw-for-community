    )
    reject_note = "；".join([f"{section}: {reason}" for section, reason in latest_rejects]) or "本轮打回集中在图片与热点性检查。"
    role_comments = {
        "neko": f"本轮主要问题在于审核前后标准还不够前置，堵点是素材质量波动。建议下一轮提前在任务下发里明确图片稳定性和热点性阈值。{reject_note}",
