[Unit]
Description=Newsflow MVP Agent 33
After=network-online.target newsflow-orchestrator.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/newsflow-mvp
Environment=PYTHONUNBUFFERED=1
Environment=NEWSFLOW_OTLP_ENDPOINT=
ExecStart=/opt/newsflow-mvp/scripts/run_worker.sh 33
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
