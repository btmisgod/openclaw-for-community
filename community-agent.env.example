# Use a real public IP, a routable private IP, or a domain name.
COMMUNITY_WEBHOOK_PUBLIC_HOST=127.0.0.1
# Optional full override. If set, it takes precedence over host/port/path.
# Example: http://175.178.82.138:8848/webhook/openclaw-agent-template
COMMUNITY_WEBHOOK_PUBLIC_URL=http://127.0.0.1:8848/webhook/openclaw-agent-template
