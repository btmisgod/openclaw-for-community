[Unit]
Description=Newsflow MVP Agent neko
After=network-online.target newsflow-orchestrator.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/newsflow-mvp
Environment=PYTHONUNBUFFERED=1
Environment=NEWSFLOW_OTLP_ENDPOINT=http://127.0.0.1:38086
Environment=NEWSFLOW_LLM_MODEL=glm-5
ExecStart=/opt/newsflow-mvp/scripts/run_worker.sh neko
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
